# ============================================================
# LegalKan — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the real values

# ----- OpenAI (for AI contract generation) -----
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=placeholder

# ----- Xendit (for Virtual Account payment) -----
# Sign up at: https://dashboard.xendit.co
# Use TEST keys from: https://dashboard.xendit.co/settings/developers#api-keys
XENDIT_SECRET_KEY=placeholder
# Your Xendit Callback Verification Token (from dashboard → Webhooks)
XENDIT_CALLBACK_TOKEN=placeholder

# ----- Resend (for email delivery) -----
# Sign up at: https://resend.com and verify your domain
RESEND_API_KEY=placeholder
EMAIL_FROM=noreply@legal-kan.com

# ----- App Config -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PRICE=29000

# ----- Crisp Live Chat -----
# Sign up at: https://crisp.chat and create a website.
# Find your Website ID in Crisp Dashboard → Settings → Integrations → Chat Widget.
NEXT_PUBLIC_CRISP_WEBSITE_ID=your_crisp_website_id_here

# ----- PostHog Analytics -----
# Sign up at: https://posthog.com and create a project.
# Find your API key in PostHog → Project Settings → Project API Key.
NEXT_PUBLIC_POSTHOG_KEY=your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ----- Supabase (Customer + Order Database) -----
# Sign up at: https://supabase.com and create a new project.
# After running docs/supabase-schema.sql, fill in the values below.
# Find them in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
